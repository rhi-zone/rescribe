{
  "description": "Basic TSV table with 2 header columns and 2 data rows",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "table" },
    { "path": "/0/0", "kind": "table_row" },
    { "path": "/0/0/0", "kind": "table_header" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "Name" } },
    { "path": "/0/0/1", "kind": "table_header" },
    { "path": "/0/0/1/0", "kind": "text", "props": { "content": "Age" } },
    { "path": "/0/1", "kind": "table_row" },
    { "path": "/0/1/0", "kind": "table_cell" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "Alice" } },
    { "path": "/0/1/1", "kind": "table_cell" },
    { "path": "/0/1/1/0", "kind": "text", "props": { "content": "30" } },
    { "path": "/0/2", "kind": "table_row" },
    { "path": "/0/2/0", "kind": "table_cell" },
    { "path": "/0/2/0/0", "kind": "text", "props": { "content": "Bob" } },
    { "path": "/0/2/1", "kind": "table_cell" },
    { "path": "/0/2/1/0", "kind": "text", "props": { "content": "25" } }
  ]
}
