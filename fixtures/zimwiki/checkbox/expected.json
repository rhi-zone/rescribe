{
  "description": "Checkbox list items with checked and unchecked states",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "list" },
    { "path": "/0/0", "kind": "list_item", "props": { "checked": false } },
    { "path": "/0/1", "kind": "list_item", "props": { "checked": true } },
    { "path": "/0/2", "kind": "list_item", "props": { "checked": true } }
  ]
}
