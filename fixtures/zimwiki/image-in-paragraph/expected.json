{
  "description": "Image embedded within a text paragraph",
  "category": "integration",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "Here is an image " } },
    { "path": "/0/1", "kind": "image", "props": { "url": "photo.png" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " in a paragraph." } }
  ]
}
