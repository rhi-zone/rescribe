{
  "description": "Bold inline inside a list item",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "list" },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "strong" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "bold" } },
    { "path": "/0/0/1", "kind": "text", "props": { "content": " item" } }
  ]
}
