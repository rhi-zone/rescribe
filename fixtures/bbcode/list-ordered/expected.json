{
  "description": "Ordered list with two items",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "list", "props": { "ordered": true } },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "first" } },
    { "path": "/0/1", "kind": "list_item" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "second" } }
  ]
}
