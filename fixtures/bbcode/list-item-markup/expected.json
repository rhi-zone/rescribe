{
  "description": "List items containing inline markup",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "list" },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "strong" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "bold item" } },
    { "path": "/0/1", "kind": "list_item" },
    { "path": "/0/1/0", "kind": "emphasis" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "italic item" } }
  ]
}
