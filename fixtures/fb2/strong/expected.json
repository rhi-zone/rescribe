{
  "description": "strong element becomes a strong node",
  "assertions": [
    { "path": "/0",         "kind": "div" },
    { "path": "/0/0",       "kind": "div" },
    { "path": "/0/0/0",     "kind": "paragraph" },
    { "path": "/0/0/0/0",   "kind": "strong" },
    { "path": "/0/0/0/0/0", "kind": "text", "props": { "content": "bold text" } }
  ]
}
