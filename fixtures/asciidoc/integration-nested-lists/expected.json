{
  "description": "Unordered sub-list nested inside a top-level unordered list item",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "list", "props": { "ordered": false }, "children_count": 2 },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "First item" } },
    { "path": "/0/0/1", "kind": "list", "props": { "ordered": false }, "children_count": 2 },
    { "path": "/0/0/1/0", "kind": "list_item" },
    { "path": "/0/0/1/0/0/0", "kind": "text", "props": { "content": "nested alpha" } },
    { "path": "/0/0/1/1/0/0", "kind": "text", "props": { "content": "nested beta" } },
    { "path": "/0/1", "kind": "list_item" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "Second item" } }
  ]
}
