{
  "description": "AsciiDoc inline footnote macros: anonymous, named, and back-reference",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "See " } },
    { "path": "/0/1", "kind": "footnote_ref" },
    { "path": "/0/2", "kind": "footnote_def" },
    { "path": "/0/2/0", "kind": "text", "props": { "content": "Some footnote text" } },
    { "path": "/1", "kind": "paragraph" },
    { "path": "/1/0", "kind": "text", "props": { "content": "Named " } },
    { "path": "/1/1", "kind": "footnote_ref", "props": { "label": "fn-named" } },
    { "path": "/1/2", "kind": "footnote_def", "props": { "label": "fn-named" } },
    { "path": "/1/2/0", "kind": "text", "props": { "content": "Named footnote text" } },
    { "path": "/2", "kind": "paragraph" },
    { "path": "/2/0", "kind": "text", "props": { "content": "Back reference " } },
    { "path": "/2/1", "kind": "footnote_ref", "props": { "label": "fn-named" } },
    { "path": "/2/2", "kind": "text", "props": { "content": " here." } }
  ]
}
