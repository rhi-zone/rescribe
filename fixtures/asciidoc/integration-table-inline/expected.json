{
  "description": "Table cell containing bold inline markup",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "table", "children_count": 1 },
    { "path": "/0/0", "kind": "table_row", "children_count": 2 },
    { "path": "/0/0/0", "kind": "table_cell" },
    { "path": "/0/0/0/0", "kind": "strong" },
    { "path": "/0/0/0/0/0", "kind": "text", "props": { "content": "bold" } },
    { "path": "/0/0/1", "kind": "table_cell" },
    { "path": "/0/0/1/0", "kind": "text", "props": { "content": "plain" } }
  ]
}
