{
  "description": "Quote block delimited by ____ produces a blockquote",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "blockquote" },
    { "path": "/0/0", "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "This is a blockquote." } }
  ]
}
