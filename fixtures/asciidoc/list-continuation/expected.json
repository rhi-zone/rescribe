{
  "description": "List continuation (+) attaches a following paragraph to the preceding list item",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "list", "props": { "ordered": false }, "children_count": 2 },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "Item 1" } },
    { "path": "/0/0/1", "kind": "paragraph" },
    { "path": "/0/0/1/0", "kind": "text", "props": { "content": "Continuation paragraph." } },
    { "path": "/0/1", "kind": "list_item" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "Item 2" } }
  ]
}
