{
  "description": "<<id>> bibliography cross-reference is parsed the same as an xref: a link node with url = #id",
  "category": "rare",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "See " } },
    { "path": "/0/1", "kind": "link", "props": { "url": "#smith2020" } },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "smith2020" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " for details." } }
  ]
}
