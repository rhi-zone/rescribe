{
  "description": ".Title before a block attaches a title property to the block's div wrapper",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "div", "props": { "class": "example", "title": "My Title" } },
    { "path": "/0/0", "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "Example content." } }
  ]
}
