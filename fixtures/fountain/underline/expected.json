{
  "description": "Underline with _text_ produces underline inline",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "paragraph", "props": { "fountain:type": "action" } },
    { "path": "/0/0", "kind": "text", "props": { "content": "The " } },
    { "path": "/0/1", "kind": "underline" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "important" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " document." } }
  ]
}
