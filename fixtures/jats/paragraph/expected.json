{
  "description": "A simple paragraph in a JATS article body becomes doc > div > paragraph > text",
  "category": "happy",
  "assertions": [
    { "path": "/",     "kind": "document" },
    { "path": "/0",    "kind": "div" },
    { "path": "/0/0",  "kind": "paragraph" },
    { "path": "/0/0/0","kind": "text", "props": { "content": "Hello world." } }
  ]
}
