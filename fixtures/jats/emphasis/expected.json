{
  "description": "A JATS italic element inside a paragraph becomes an emphasis node wrapping a text node",
  "category": "happy",
  "assertions": [
    { "path": "/",        "kind": "document" },
    { "path": "/0",       "kind": "div" },
    { "path": "/0/0",     "kind": "paragraph" },
    { "path": "/0/0/0",   "kind": "emphasis" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "emphasized text" } }
  ]
}
