{
  "description": "Loose list (blank lines between items) — list items contain paragraph nodes",
  "category": "rare",
  "assertions": [
    { "path": "/0",     "kind": "list", "props": { "ordered": false } },
    { "path": "/0/0",   "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/1",   "kind": "list_item" },
    { "path": "/0/1/0", "kind": "paragraph" },
    { "path": "/0/2",   "kind": "list_item" },
    { "path": "/0/2/0", "kind": "paragraph" }
  ]
}
