{
  "description": "Full reference link [display][target] resolves url and title from the definition",
  "category": "rare",
  "assertions": [
    { "path": "/0",   "kind": "paragraph" },
    { "path": "/0/0", "kind": "link", "props": { "url": "https://example.com", "title": "Page Title" } },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "display text" } }
  ]
}
