{
  "description": "Ordered list starting at 3 produces list node with start=3",
  "category": "rare",
  "assertions": [
    { "path": "/0",   "kind": "list", "props": { "ordered": true, "start": 3 } },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/1", "kind": "list_item" },
    { "path": "/0/2", "kind": "list_item" }
  ]
}
