{
  "description": "RTF simple two-column table",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "table" },
    { "path": "/0/0", "kind": "table_row" },
    { "path": "/0/0/0", "kind": "table_cell" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "Cell 1" } },
    { "path": "/0/0/1", "kind": "table_cell" },
    { "path": "/0/0/1/0", "kind": "text", "props": { "content": "Cell 2" } }
  ]
}
