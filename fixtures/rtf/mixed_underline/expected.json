{
  "description": "Paragraph with plain text before and after an underline span",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "plain " } },
    { "path": "/0/1", "kind": "underline" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "underline" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " plain" } }
  ]
}
