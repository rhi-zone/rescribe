{
  "description": "RTF inline footnote — body text with footnote_ref embedded",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/1", "kind": "footnote_ref" },
    { "path": "/0/1/0", "kind": "paragraph" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "Footnote content" } }
  ]
}
