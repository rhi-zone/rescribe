{
  "description": "RTF all-caps formatting (\\caps)",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "normal " } },
    { "path": "/0/1", "kind": "all_caps" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "ALL CAPS TEXT" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " normal" } }
  ]
}
