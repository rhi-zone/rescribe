{
  "description": "RTF hidden text (\\v)",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "visible " } },
    { "path": "/0/1", "kind": "hidden" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "hidden text" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " visible" } }
  ]
}
