{
  "description": "RTF ordered (numbered) list using \\pnlvlbody",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "list", "props": { "ordered": true } },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/1", "kind": "list_item" },
    { "path": "/0/1/0", "kind": "paragraph" }
  ]
}
