{
  "description": "Angle bracket autolinks become link nodes",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/1", "kind": "link", "props": { "url": "https://example.com" } },
    { "path": "/1", "kind": "paragraph" },
    { "path": "/1/1", "kind": "link", "props": { "url": "user@example.com" } }
  ]
}
