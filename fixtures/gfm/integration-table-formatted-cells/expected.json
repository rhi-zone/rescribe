{
  "description": "Table cells with inline formatting produce inline nodes nested in table_cell",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "table" },
    { "path": "/0/1/0/0", "kind": "strong" },
    { "path": "/0/1/1/0", "kind": "emphasis" },
    { "path": "/0/2/0/0", "kind": "code" },
    { "path": "/0/2/1/0", "kind": "strikeout" }
  ]
}
