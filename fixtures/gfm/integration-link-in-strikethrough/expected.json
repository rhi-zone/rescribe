{
  "description": "Link nested inside strikethrough produces link node inside strikeout node",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "strikeout" },
    { "path": "/0/0/0", "kind": "link", "props": { "url": "https://example.com" } }
  ]
}
