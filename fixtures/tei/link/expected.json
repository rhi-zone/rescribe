{
  "description": "ref element with target attribute produces link(url=...) > text",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "link", "props": { "url": "https://example.com" } },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "Example" } }
  ]
}
