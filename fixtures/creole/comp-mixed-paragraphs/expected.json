{
  "description": "Multiple paragraphs with mixed inline markup",
  "category": "composition",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/1", "kind": "strong" },
    { "path": "/1", "kind": "paragraph" },
    { "path": "/1/1", "kind": "emphasis" },
    { "path": "/1/3", "kind": "link", "props": { "url": "https://example.com" } }
  ]
}
