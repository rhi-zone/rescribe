{
  "description": "BibLaTeX @incollection entry becomes biblatex:entry with biblatex:type incollection",
  "assertions": [
    { "path": "/0",     "kind": "definition_list" },
    { "path": "/0/0",   "kind": "biblatex:entry" },
    { "path": "/0/0/1", "kind": "definition_desc", "props": { "biblatex:type": "incollection" } }
  ]
}
