{
  "description": "Inline markup inside list items",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "list" },
    { "path": "/0/0", "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/0/0/0", "kind": "strong" },
    { "path": "/0/0/0/0/0", "kind": "text", "props": { "content": "bold" } }
  ]
}
