{
  "description": "Inline markup inside table cells",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "table" },
    { "path": "/0/1/0", "kind": "table_cell" },
    { "path": "/0/1/0/0", "kind": "strong" },
    { "path": "/0/1/0/0/0", "kind": "text", "props": { "content": "bold" } }
  ]
}
