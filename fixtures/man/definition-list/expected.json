{
  "description": ".TP macro produces a definition_list with a term and description",
  "assertions": [
    { "path": "/0",       "kind": "definition_list", "children_count": 2 },
    { "path": "/0/0",     "kind": "definition_term" },
    { "path": "/0/0/0",   "kind": "text", "props": { "content": "term" } },
    { "path": "/0/1",     "kind": "definition_desc" },
    { "path": "/0/1/0",   "kind": "paragraph" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "description text" } }
  ]
}
