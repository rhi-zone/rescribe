{
  "description": "\\f(CW...\\fR produces an inline code node",
  "assertions": [
    { "path": "/0",   "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "Use " } },
    { "path": "/0/1", "kind": "code", "props": { "content": "command" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " to run it." } }
  ]
}
