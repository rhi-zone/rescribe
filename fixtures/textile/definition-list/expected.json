    { "path": "/0/1", "kind": "definition_desc" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "A hot beverage" } },
    { "path": "/0/2", "kind": "definition_term" },
    { "path": "/0/2/0", "kind": "text", "props": { "content": "Tea" } },
    { "path": "/0/3", "kind": "definition_desc" },
    { "path": "/0/3/0", "kind": "text", "props": { "content": "Another hot beverage" } }
  ]
}
