{
  "description": "Textile nested list produces list_item containing nested list",
  "assertions": [
    { "path": "/0",       "kind": "list", "props": { "ordered": false } },
    { "path": "/0/0",     "kind": "list_item" },
    { "path": "/0/0/1",   "kind": "list" },
    { "path": "/0/0/1/0", "kind": "list_item" },
    { "path": "/0/1",     "kind": "list_item" }
  ]
}
