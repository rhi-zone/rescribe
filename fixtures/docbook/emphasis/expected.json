{
  "description": "emphasis without role attribute becomes an emphasis node",
  "assertions": [
    { "path": "/0",     "kind": "div" },
    { "path": "/0/0",   "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "emphasis" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "italic text" } }
  ]
}
