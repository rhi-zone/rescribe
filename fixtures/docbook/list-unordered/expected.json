{
  "description": "itemizedlist becomes list(ordered=false); each listitem becomes list_item containing a paragraph",
  "assertions": [
    { "path": "/0",       "kind": "div" },
    { "path": "/0/0",     "kind": "list", "props": { "ordered": false }, "children_count": 3 },
    { "path": "/0/0/0",   "kind": "list_item" },
    { "path": "/0/0/0/0", "kind": "paragraph" },
    { "path": "/0/0/0/0/0", "kind": "text", "props": { "content": "First item" } },
    { "path": "/0/0/1",   "kind": "list_item" },
    { "path": "/0/0/2",   "kind": "list_item" }
  ]
}
