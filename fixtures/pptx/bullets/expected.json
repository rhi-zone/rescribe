{
  "description": "PPTX slide with bullet list paragraphs grouped into list/list_item nodes",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "div", "props": { "slide": 1 } },
    { "path": "/0/0", "kind": "heading", "props": { "level": 1 } },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "Bullet Slide" } },
    { "path": "/0/1", "kind": "list", "props": { "ordered": false } },
    { "path": "/0/1/0", "kind": "list_item" },
    { "path": "/0/1/0/0", "kind": "paragraph" },
    { "path": "/0/1/0/0/0", "kind": "text", "props": { "content": "First bullet" } },
    { "path": "/0/1/1", "kind": "list_item" },
    { "path": "/0/1/1/0", "kind": "paragraph" },
    { "path": "/0/1/1/0/0", "kind": "text", "props": { "content": "Second bullet" } },
    { "path": "/0/1/2", "kind": "list_item" },
    { "path": "/0/1/2/0", "kind": "paragraph" },
    { "path": "/0/1/2/0/0", "kind": "text", "props": { "content": "Third bullet" } }
  ]
}
