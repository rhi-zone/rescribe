      "kind": "document",
      "path": "/"
    },
    {
      "kind": "div",
      "path": "/0",
      "props": {
        "slide": 1
      }
    },
    {
      "kind": "heading",
      "path": "/0/0",
      "props": {
        "level": 1
      }
    },
    {
