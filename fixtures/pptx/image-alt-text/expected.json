      "path": "/0/0/0",
      "props": {
        "content": "Image With Alt Text"
      }
    },
    {
      "kind": "image",
      "path": "/0/1",
      "props": {
        "alt": "A decorative red square"
      }
    }
  ],
  "category": "happy",
  "description": "PPTX image with description mapped to image node with alt property"
}