{
  "assertions": [
    {
      "kind": "document",
      "path": "/"
    },
    {
      "kind": "div",
      "path": "/0",
      "props": {
        "slide": 1
      }
    },
    {
      "kind": "heading",
      "path": "/0/0",
      "props": {
        "level": 1
      }
    },
    {
      "kind": "text",
      "path": "/0/0/0",
      "props": {
        "content": "Slide With Notes"
      }
    },
    {
      "kind": "paragraph",
      "path": "/0/1"
    },
    {
      "kind": "text",
      "path": "/0/1/0",
      "props": {
        "content": "Main content."
      }
    },
    {
      "kind": "div",
      "path": "/0/2",
      "props": {
        "notes": true
      }
    },
    {
      "kind": "paragraph",
      "path": "/0/2/0"
    },
    {
      "kind": "text",
      "path": "/0/2/0/0",
      "props": {
        "content": "These are the speaker notes for this slide."
      }
    }
  ],
  "category": "happy",
  "description": "PPTX speaker notes become a div[notes] node"
}