{
  "description": "Nested bold and italic via sequential ANSI codes",
  "category": "rare",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "strong" },
    { "path": "/0/0/0", "kind": "emphasis" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "Hello" } }
  ]
}
