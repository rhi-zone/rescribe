{
  "description": "Explicit newline mid-paragraph as line break",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "Hello" } },
    { "path": "/0/1", "kind": "line_break" },
    { "path": "/0/2", "kind": "text", "props": { "content": "World" } }
  ]
}
