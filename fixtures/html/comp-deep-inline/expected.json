{
  "description": "deeply nested inline nodes are preserved through multiple levels of nesting",
  "category": "integration",
  "assertions": [
    { "path": "/0",         "kind": "paragraph" },
    { "path": "/0/0",       "kind": "link", "props": { "url": "https://example.com" } },
    { "path": "/0/0/0",     "kind": "emphasis" },
    { "path": "/0/0/0/0",   "kind": "strong" },
    { "path": "/0/0/0/0/0", "kind": "text", "props": { "content": "deep" } }
  ]
}
