    { "path": "/0/0",       "kind": "table_body" },
    { "path": "/0/0/0",     "kind": "table_row" },
    { "path": "/0/0/0/0",   "kind": "table_cell" },
    { "path": "/0/0/0/0/0", "kind": "strong" },
    { "path": "/0/0/0/0/1", "kind": "text" },
    { "path": "/0/0/0/0/2", "kind": "emphasis" }
  ]
}
