{
  "description": "mark element becomes span with html:tag=mark",
  "assertions": [
    { "path": "/0",     "kind": "paragraph" },
    { "path": "/0/0",   "kind": "text", "props": { "content": "This is " } },
    { "path": "/0/1",   "kind": "span", "props": { "html:tag": "mark" } },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "highlighted" } },
    { "path": "/0/2",   "kind": "text", "props": { "content": " text." } }
  ]
}
