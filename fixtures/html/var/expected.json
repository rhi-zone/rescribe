{
  "description": "var element becomes span with html:tag=var",
  "assertions": [
    { "path": "/0",     "kind": "paragraph" },
    { "path": "/0/0",   "kind": "text", "props": { "content": "The variable " } },
    { "path": "/0/1",   "kind": "span", "props": { "html:tag": "var" } },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "x" } },
    { "path": "/0/2",   "kind": "text", "props": { "content": " is defined." } }
  ]
}
