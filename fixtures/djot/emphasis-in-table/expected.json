{
  "description": "Emphasis inline markup inside a table cell is parsed correctly",
  "category": "integration",
  "assertions": [
    { "path": "/0", "kind": "table" },
    { "path": "/0/0", "kind": "table_row" },
    { "path": "/0/0/0", "kind": "table_header" },
    { "path": "/0/1", "kind": "table_row" },
    { "path": "/0/1/0", "kind": "table_cell" },
    { "path": "/0/1/0/0", "kind": "emphasis" },
    { "path": "/0/1/0/0/0", "kind": "text", "props": { "content": "italic" } }
  ]
}
