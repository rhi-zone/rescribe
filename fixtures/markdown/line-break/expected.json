{
  "description": "Two trailing spaces produce a hard line_break node",
  "assertions": [
    { "path": "/0/0", "kind": "text",       "props": { "content": "first line" } },
    { "path": "/0/1", "kind": "line_break", "children_count": 0 },
    { "path": "/0/2", "kind": "text",       "props": { "content": "second line" } }
  ]
}
