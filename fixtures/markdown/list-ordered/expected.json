{
  "description": "Tight ordered list has ordered=true; list_item children are text nodes directly",
  "assertions": [
    { "path": "/0",     "kind": "list", "props": { "ordered": true }, "children_count": 2 },
    { "path": "/0/0",   "kind": "list_item" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "first" } },
    { "path": "/0/1",   "kind": "list_item" }
  ]
}
