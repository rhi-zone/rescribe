{
  "description": "DOCX run with bold formatting produces strong node",
  "category": "happy",
  "assertions": [
    { "path": "/",       "kind": "document" },
    { "path": "/0",      "kind": "paragraph" },
    { "path": "/0/0",    "kind": "strong" },
    { "path": "/0/0/0",  "kind": "text", "props": { "content": "bold text" } }
  ]
}
