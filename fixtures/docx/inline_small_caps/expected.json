{
  "description": "DOCX small-caps run produces a small_caps wrapper node",
  "category": "happy",
  "assertions": [
    { "path": "/",       "kind": "document" },
    { "path": "/0",      "kind": "paragraph" },
    { "path": "/0/0",    "kind": "small_caps" },
    { "path": "/0/0/0",  "kind": "text", "props": { "content": "Small Caps Text" } }
  ]
}
