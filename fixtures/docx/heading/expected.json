{
  "description": "DOCX document with level-1 heading and paragraph",
  "category": "happy",
  "assertions": [
    { "path": "/", "kind": "document" },
    { "path": "/0", "kind": "heading", "props": { "level": 1 } },
    { "path": "/0/0", "kind": "text", "props": { "content": "My Heading" } },
    { "path": "/1", "kind": "paragraph" },
    { "path": "/1/0", "kind": "text", "props": { "content": "Some content." } }
  ]
}
