{
  "description": "DOCX footnote reference produces footnote_ref node with footnote content as children",
  "category": "happy",
  "assertions": [
    { "path": "/",         "kind": "document" },
    { "path": "/0",        "kind": "paragraph" },
    { "path": "/0/0",      "kind": "text", "props": { "content": "Body text." } },
    { "path": "/0/1",      "kind": "footnote_ref", "props": { "label": "1" } },
    { "path": "/0/1/0",    "kind": "paragraph" },
    { "path": "/0/1/0/0",  "kind": "text", "props": { "content": "Footnote text." } }
  ]
}
