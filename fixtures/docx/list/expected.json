{
  "description": "DOCX paragraphs with same numbering id are grouped into a list node",
  "category": "happy",
  "assertions": [
    { "path": "/",       "kind": "document" },
    { "path": "/0",      "kind": "list", "props": { "ordered": false } },
    { "path": "/0/0",    "kind": "list_item" },
    { "path": "/0/0/0",  "kind": "text", "props": { "content": "first item" } },
    { "path": "/0/1",    "kind": "list_item" },
    { "path": "/0/1/0",  "kind": "text", "props": { "content": "second item" } }
  ]
}
