{
  "description": "W> prefix produces a div node with class=warning",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "div", "props": { "class": "warning" } },
    { "path": "/0/0", "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "This is a warning." } }
  ]
}
