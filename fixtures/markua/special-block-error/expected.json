{
  "description": "E> prefix produces a div node with class=error",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "div", "props": { "class": "error" } },
    { "path": "/0/0", "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "This is an error." } }
  ]
}
