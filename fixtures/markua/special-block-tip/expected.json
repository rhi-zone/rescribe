{
  "description": "T> prefix produces a div node with class=tip",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "div", "props": { "class": "tip" } },
    { "path": "/0/0", "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "This is a tip." } }
  ]
}
