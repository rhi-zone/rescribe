{
  "description": "Bold-italic with __text__; renders as strong > emphasis",
  "category": "happy",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/0", "kind": "text", "props": { "content": "This is " } },
    { "path": "/0/1", "kind": "strong" },
    { "path": "/0/1/0", "kind": "emphasis" },
    { "path": "/0/1/0/0", "kind": "text", "props": { "content": "bold-italic" } },
    { "path": "/0/2", "kind": "text", "props": { "content": " text." } }
  ]
}
