{
  "description": "#+CAPTION: before a table produces a figure wrapping the caption and table",
  "assertions": [
    { "path": "",     "kind": "document", "children_count": 1 },
    { "path": "/0",   "kind": "figure" },
    { "path": "/0/0", "kind": "caption" },
    { "path": "/0/1", "kind": "table" },
    { "path": "/0/1/0", "kind": "table_row" },
    { "path": "/0/1/0/0", "kind": "table_header" }
  ]
}
