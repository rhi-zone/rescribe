{
  "description": "Table cell with bold inline markup produces table_cell containing strong",
  "assertions": [
    { "path": "/0",       "kind": "table" },
    { "path": "/0/0",     "kind": "table_row" },
    { "path": "/0/0/0",   "kind": "table_cell" },
    { "path": "/0/0/0/0", "kind": "strong" },
    { "path": "/0/0/1",   "kind": "table_cell" }
  ]
}
