{
  "description": "Nested BEGIN_QUOTE blocks produce nested blockquote nodes",
  "assertions": [
    { "path": "/0",         "kind": "blockquote" },
    { "path": "/0/0",       "kind": "paragraph" },
    { "path": "/0/0/0",     "kind": "text", "props": { "content": "Outer quote text." } },
    { "path": "/0/1",       "kind": "blockquote" },
    { "path": "/0/1/0",     "kind": "paragraph" },
    { "path": "/0/1/0/0",   "kind": "text", "props": { "content": "Inner nested quote." } },
    { "path": "/0/2",       "kind": "paragraph" },
    { "path": "/0/2/0",     "kind": "text", "props": { "content": "More outer text." } }
  ]
}
