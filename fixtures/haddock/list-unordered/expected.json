{
  "description": "Unordered list with * items produces unordered_list > list_item > text",
  "assertions": [
    { "path": "/0",       "kind": "unordered_list", "children_count": 3 },
    { "path": "/0/0",     "kind": "list_item" },
    { "path": "/0/0/0",   "kind": "text", "props": { "content": "alpha" } }
  ]
}
