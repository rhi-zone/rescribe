{
  "description": "<url> bare URL syntax produces a link node with matching url and text",
  "assertions": [
    { "path": "/0",     "kind": "paragraph" },
    { "path": "/0/0",   "kind": "link", "props": { "url": "https://example.com" } },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "https://example.com" } }
  ]
}
