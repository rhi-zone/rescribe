{
  "description": "Anonymous hyperlink `text`__ resolved from __ url target in order",
  "category": "rare",
  "assertions": [
    { "path": "/0", "kind": "paragraph" },
    { "path": "/0/1", "kind": "link", "props": { "url": "https://example.com" } },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "Example" } }
  ]
}
