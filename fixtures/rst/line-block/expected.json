{
  "description": "RST line block (| prefix) becomes div with class line-block; each line is a paragraph",
  "category": "rare",
  "assertions": [
    { "path": "/0", "kind": "div", "props": { "class": "line-block" } },
    { "path": "/0/0", "kind": "paragraph" },
    { "path": "/0/0/0", "kind": "text", "props": { "content": "Line one" } },
    { "path": "/0/1", "kind": "paragraph" },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "Line two" } },
    { "path": "/0/2", "kind": "paragraph" },
    { "path": "/0/2/0", "kind": "text", "props": { "content": "Line three" } }
  ]
}
