{
  "description": "=over/=item */=back with bullet items produces an unordered list",
  "assertions": [
    { "path": "/0",     "kind": "list", "props": { "ordered": false }, "children_count": 3 },
    { "path": "/0/0",   "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "Alpha" } },
    { "path": "/0/1",   "kind": "list_item" },
    { "path": "/0/2",   "kind": "list_item" }
  ]
}
