{
  "description": "=item with plain text (no bullet or number) puts the item text as a paragraph inside list_item",
  "category": "rare",
  "assertions": [
    { "path": "/0",       "kind": "list", "props": { "ordered": false }, "children_count": 1 },
    { "path": "/0/0",     "kind": "list_item" },
    { "path": "/0/0/0",   "kind": "paragraph" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "First" } },
    { "path": "/0/0/1",   "kind": "paragraph" },
    { "path": "/0/0/1/0", "kind": "text", "props": { "content": "Description of first item." } }
  ]
}
