{
  "description": "L<text|/\"section\"> produces a link with label and section target",
  "assertions": [
    { "path": "/0",     "kind": "paragraph" },
    { "path": "/0/1",   "kind": "link", "props": { "url": "/\"DESCRIPTION\"" } },
    { "path": "/0/1/0", "kind": "text", "props": { "content": "the description" } }
  ]
}
