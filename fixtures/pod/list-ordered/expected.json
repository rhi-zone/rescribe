{
  "description": "=over/=item N./=back with numbered items produces an ordered list",
  "assertions": [
    { "path": "/0",     "kind": "list", "props": { "ordered": true }, "children_count": 3 },
    { "path": "/0/0",   "kind": "list_item" },
    { "path": "/0/0/0", "kind": "paragraph" },
    { "path": "/0/0/0/0", "kind": "text", "props": { "content": "First" } },
    { "path": "/0/1",   "kind": "list_item" },
    { "path": "/0/2",   "kind": "list_item" }
  ]
}
